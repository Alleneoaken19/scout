# ============================================================
# Scout Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You only need ONE AI provider. Pick the one you prefer.
# ============================================================

# --- AI Provider (choose one) --------------------------------

# OPTION 1: Google Gemini (FREE)
# Get your key at: https://aistudio.google.com/app/apikey
# AI_PROVIDER=gemini
# AI_API_KEY=your-gemini-key
# AI_MODEL=gemini-2.0-flash

# OPTION 2: Ollama (FREE, runs on your machine)
# Install: https://ollama.com/download
# Then run: ollama pull llama3.2 && ollama serve
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2

# OPTION 3: Anthropic Claude (PAID, ~$5/month, best quality)
# Get your key at: https://console.anthropic.com/settings/keys
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-your-key-here
# AI_MODEL=claude-haiku-4-5-20251001

# Uncomment and fill in ONE of the options above:
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# --- Optional: Notion integration ----------------------------
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_JOBS_DB_ID=

# --- Optional: Adzuna job source ------------------------------
# Free API key at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Gmail + Google Sheets tokens are auto-saved to config/credentials/
# after running: scout auth gmail / scout auth sheets
